{
  "name": "head-start",
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "config/datocms"
  ],
  "license": "ISC",
  "scripts": {
    "analyze": "ANALYZE=true npm run build",
    "astro": "astro",
    "prebuild": "run-s prep",
    "build": "astro build",
    "postbuild": "npm run post",
    "cloudflare:build": "jiti scripts/build.ts",
    "create": "plop --plopfile config/plop/plopfile.mjs",
    "create:api": "plop --plopfile config/plop/plopfile.mjs api",
    "create:block": "plop --plopfile config/plop/plopfile.mjs block",
    "create:component": "plop --plopfile config/plop/plopfile.mjs component",
    "create:page": "plop --plopfile config/plop/plopfile.mjs page",
    "predev": "run-s prep",
    "dev": "run-p dev:* --print-label",
    "dev:astro": "astro dev",
    "dev:graphql": "chokidar 'src/**/*.graphql' -c 'npm run prep:datocms-types'",
    "dev:icons": "chokidar 'src/assets/icons/*.svg' -c 'npm run prep:icons'",
    "dev:translations": "node scripts/watch-translations.ts",
    "prep": "run-s prep:* --print-label",
    "prep:clean-astro-env": "rm -rf node_modules/.astro",
    "prep:cloudflare-env": "touch .dev.vars",
    "prep:datocms-types": "graphql-codegen --config .graphqlrc.ts",
    "prep:download-file-proxy-map": "node scripts/download-file-proxy-map.ts",
    "prep:download-redirects": "node scripts/download-redirects.ts",
    "prep:download-site-data": "node scripts/download-site-data.ts",
    "prep:download-translations": "node scripts/download-translations.ts",
    "prep:download-item-types": "node scripts/download-item-types.ts",
    "prep:icons": "svg-sprite --svg-doctype=false --symbol --symbol-dest='src/assets' --symbol-sprite=icon-sprite.svg src/assets/icons/*.svg && jiti scripts/icon-types.ts",
    "preview": "wrangler pages dev ./dist",
    "lint": "run-s lint:* --print-label",
    "lint:astro": "astro check",
    "lint:eslint": "eslint .",
    "lint:html": "html-validate --config config/htmlvalidate/config.json dist/",
    "pretest": "npm run prep",
    "test": "run-s test:*",
    "test:unit": "vitest run",
    "post": "run-s post:* --print-label",
    "post:remove-public-dir-readme": "rm dist/README.md",
    "postinstall": "husky",
    "seed:docs": "npm run seed:docs --workspace=config/datocms",
    "cms:manage": "jiti scripts/cms-manage.ts",
    "cms:environments:create": "jiti scripts/cms-create-environment.ts",
    "cms:environments:destroy": "jiti scripts/cms-destroy-environment.ts",
    "cms:environments:sync": "jiti scripts/cms-sync-environment.ts",
    "cms:environments:promote": "jiti scripts/cms-promote-environment.ts",
    "cms:migrations:generate": "jiti scripts/cms-generate-migration.ts",
    "cms:upload-block-previews": "jiti scripts/upload-block-previews.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^12.6.7",
    "@astrojs/sitemap": "^3.7.3",
    "@datocms/astro": "^0.6.12",
    "@datocms/content-link": "^0.3.22",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource/archivo": "^5.1.0",
    "@inquirer/prompts": "^8.5.2",
    "@nanostores/persistent": "^1.3.4",
    "@rollup/plugin-graphql": "^2.0.3",
    "accept-language-parser": "^1.5.0",
    "astro": "^5.18.2",
    "datocms-listen": "^0.1.15",
    "datocms-structured-text-utils": "^6.0.0",
    "get-video-id": "^4.2.0",
    "github-slugger": "^2.0.0",
    "hast-util-select": "^6.0.4",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-html": "^9.0.5",
    "hast-util-to-string": "^3.0.1",
    "hls.js": "^1.6.16",
    "html-validate": "^11.5.3",
    "jiti": "^2.7.0",
    "nanostores": "^1.3.0",
    "oembed-providers": "^1.0.20260421",
    "pretty-bytes": "^7.1.0",
    "promise-all-props": "^3.0.0",
    "regexparam": "^3.0.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "rosetta": "^1.1.0",
    "scule": "^1.3.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.9",
    "@datocms/cli": "^4.0.28",
    "@datocms/cma-client-node": "^5.4.18",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-document-nodes": "^6.0.0",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/accept-language-parser": "^1.5.6",
    "@types/dotenv-safe": "^9.1.0",
    "@types/jsdom": "^28.0.3",
    "chokidar-cli": "^3.0.0",
    "datocms-listen": "^0.1.15",
    "dotenv-safe": "^9.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-depend": "^1.5.0",
    "eventsource": "^4.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.14.3",
    "nano-staged": "^1.0.2",
    "npm-run-all": "^4.1.5",
    "plop": "^4.0.5",
    "proper-tags": "^2.0.2",
    "robots-parser": "^3.0.1",
    "sonda": "^0.11.1",
    "svg-sprite": "^2.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.87.0"
  },
  "nano-staged": {
    "*.{astro,js,ts}": "npm run lint:eslint -- --fix --max-warnings 0"
  }
}
