---
import Layout from '~/layouts/Default.astro';
import AiSearchWidget from '~/components/AiSearch/AiSearch.astro';
import { locales } from '~/lib/i18n';
import type { SiteLocale } from '~/lib/datocms/types';
import { noIndexTag, titleTag } from '~/lib/seo';

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: SiteLocale };
const pageTitle = 'AI Search';
const pageUrls = locales.map((l) => ({ locale: l, pathname: `/${l}/ai-search/` }));
---
<Layout
  pageUrls={pageUrls}
  seoMetaTags={[noIndexTag, titleTag(pageTitle)]}
>
  <h1>{pageTitle}</h1>
  <p>Ask a question about this site. {locale === 'en' ? '' : '(English only for now.)'}</p>
  <AiSearchWidget />
</Layout>
