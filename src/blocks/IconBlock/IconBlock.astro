---
import type { IconBlockFragment } from '~/lib/datocms/types';
import type { IconName } from '~/assets/icon-sprite';
import { stripStega } from '@datocms/content-link';
import Icon, { iconNames } from '~/components/Icon';

export interface Props {
  block: IconBlockFragment;
}

const { block } = Astro.props;
const name = stripStega(block.name);

const isIconName = (value: string): value is IconName =>
  (iconNames as readonly string[]).includes(value);
---

{
  isIconName(name) && (
    <Icon name={name} aria-label={block.name} class="icon-block" />
  )
}

<style>
  .icon-block {
    height: 1em;
    width: 1em;
    vertical-align: text-top;
  }
</style>
