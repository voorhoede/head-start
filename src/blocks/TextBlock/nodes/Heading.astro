---
import type { Heading } from 'datocms-structured-text-utils';
import HeadingComponent from '~/components/Heading/Heading.astro';

interface Props {
  node: Heading;
}

const { node } = Astro.props;

const { style, level: nodeLevel } = node;
// H1 is reserved for the page title, so we start at H2
const minimumLevel = 2;
const defaultLevel = 2;
const level = Math.max(
  minimumLevel,
  nodeLevel || defaultLevel,
) as Heading['level'];
---

<HeadingComponent level={level} class={style}><slot /></HeadingComponent>

<style>
  .centered {
    text-align: center;
  }
</style>
