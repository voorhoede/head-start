---
import type { HTMLAttributes } from 'astro/types';
import type { RecordRoute } from '@lib/routing';
import type { IconName } from '@assets/icon-sprite';
import type { IconRecord } from '@lib/datocms/types';
import Icon, { iconNames } from '@components/Icon';
import LinkToRecord from '@components/LinkToRecord/LinkToRecord.astro';

type Node = {
  meta?: {
    id: string;
    value: string;
  }[];
};

export type StructuredTextLinkRecord = RecordRoute | IconRecord;

export type Props = HTMLAttributes<'a'> & {
  node?: Node;
  link: StructuredTextLinkRecord;
};

const { link: record, node, ...props } = Astro.props;

const openInNewTab = Boolean(node?.meta?.find(entry => entry.id === 'target' && entry.value === '_blank'));

const isIconName = (name: string): name is IconName =>
  (iconNames as readonly string[]).includes(name);

const isIconRecord = (link: StructuredTextLinkRecord): link is IconRecord =>
  link.__typename === 'IconRecord';

const routeRecord = isIconRecord(record) ? null : record;
---

{
  isIconRecord(record) && record.name && isIconName(record.name) ? (
    <Icon name={record.name} aria-label={record.name} />
  ) : (
    routeRecord && (
      <LinkToRecord record={routeRecord} {openInNewTab} {...props}><slot>{routeRecord.title}</slot></LinkToRecord>
    )
  )
}
