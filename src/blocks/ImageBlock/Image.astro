---
import { Image as AstroImage } from '@datocms/astro';
import type { ComponentProps, HTMLAttributes } from 'astro/types';
import type { ImageBlockFragment } from '~/lib/datocms/types';
import { t } from '~/lib/i18n';

type ImgixParams = {
  auto?: ('format' | 'compress')[];
  quality?: number;
  fit?: string;
};

type Props = HTMLAttributes<'figure'> & {
  image: ImageBlockFragment['image'];
  priority?: boolean;
  imgixParams?: ImgixParams;
  imageProps?: Omit<
    ComponentProps<typeof AstroImage>,
    'data' | 'imgClass' | 'priority'
  >;
};

function applyImgixParams(srcSet: string, params: ImgixParams): string {
  return srcSet.replace(/https?:\/\/\S+/g, (url) => {
    const u = new URL(url);
    if (params.auto !== undefined) u.searchParams.set('auto', params.auto.join(','));
    if (params.quality !== undefined) u.searchParams.set('q', String(params.quality));
    if (params.fit !== undefined) u.searchParams.set('fit', params.fit);
    return u.toString();
  });
}

const {
  image,
  priority = false,
  imgixParams,
  imageProps,
  class: className,
  ...rest
} = Astro.props;

const alt = image.alt ?? '';

const responsiveImage = image.responsiveImage && imgixParams
  ? {
    ...image.responsiveImage,
    srcSet: applyImgixParams(image.responsiveImage.srcSet, imgixParams),
    src: applyImgixParams(image.responsiveImage.src, imgixParams),
  }
  : image.responsiveImage;
---

<figure {...rest} class:list={['image-block', className]}>
  {
    responsiveImage ? (
      // bitmap images have Imgix generated props (responsiveImage.*):
      <AstroImage
        {...imageProps}
        priority={priority}
        data={{ ...responsiveImage, alt }}
        imgClass="image-block__image"
      />
    ) : (
      // vector images do not have Imgix generated props, so using as is:
      <img
        alt={alt}
        fetchpriority={priority ? 'high' : undefined}
        loading={priority ? undefined : 'lazy'}
        decoding="async"
        src={image.url}
        width={image.width}
        height={image.height}
        class="image-block__image"
      />
    )
  }
  {
    image.title && (
      <figcaption class="image-block__caption">{image.title}</figcaption>
    )
  }
</figure>

<style
  define:vars={{
    'unavailable-message': JSON.stringify(t('image_unavailable')),
  }}
>
  /**
   * functional styling + broken image styling (only applies when image fails to load)
   * @see https://bitsofco.de/styling-broken-images/
   */
  .image-block :global(.image-block__image) {
    display: block;
    max-inline-size: 100%;
    block-size: auto;
    position: relative;
    text-align: center;
  }
  .image-block :global(.image-block__image)::after {
    content: attr(alt) ' (' var(--unavailable-message) ')';
    display: block;
    position: absolute;
    color: black;
    inset-block-start: 0;
    inset-inline-start: 0;
    inline-size: 100%;
    block-size: 100%;
    padding-block-start: calc(50% - 1em);
    background-color: #f1f1f1;
  }

  /* basic styling, can be removed */
  .image-block__caption {
    text-align: center;
  }
</style>
