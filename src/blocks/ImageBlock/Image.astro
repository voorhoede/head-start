---
import { Image as AstroImage } from '@datocms/astro';
import type { ComponentProps, HTMLAttributes } from 'astro/types';
import type { ImageBlockFragment } from '~/lib/datocms/types';
import { t } from '~/lib/i18n';

type Props = HTMLAttributes<'figure'> & {
  image: ImageBlockFragment['image']
  priority?: boolean
  imageProps?: Omit<ComponentProps<typeof AstroImage>, 'data' | 'imgClass' | 'priority'>
}

const {
  image,
  priority = false,
  imageProps,
  class: className,
  ...rest
} = Astro.props;

const alt = image.alt ?? '';
---
<figure {...rest} class:list={['image-block', className]}>
  {
    image.responsiveImage ? (
      // bitmap images have Imgix generated props (responsiveImage.*):
      <AstroImage
        {...imageProps}
        priority={priority}
        data={{ ...image.responsiveImage, alt }}
        imgClass="image-block__image"
      />
    ) : (
      // vector images do not have Imgix generated props, so using as is:
      <img
        alt={alt}
        fetchpriority={priority ? 'high' : undefined}
        loading={priority ? undefined : 'lazy'}
        decoding="async"
        src={image.url}
        width={image.width}
        height={image.height}
        class="image-block__image"
      />
    )
  }
  {image.title && <figcaption class="image-block__caption">{image.title}</figcaption>}
</figure>

<style define:vars={{ 'unavailable-message': JSON.stringify(t('image_unavailable')) }}>
  /**
   * functional styling + broken image styling (only applies when image fails to load)
   * @see https://bitsofco.de/styling-broken-images/
   */
  .image-block :global(.image-block__image) {
    display: block;
    max-width: 100%;
    height: auto;
    position: relative;
    text-align: center;

    &::after {
      content: attr(alt) ' (' var(--unavailable-message) ')';
      display: block;
      position: absolute;
      color: black;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      padding-top: calc(50% - 1em);
      background-color: #f1f1f1;
    }
  }
  
  /* basic styling, can be removed */
  .image-block__caption {
    text-align: center;
  }
</style>
