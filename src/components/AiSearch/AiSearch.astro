---
interface Props {
  endpoint?: string;
}
const { endpoint = '/api/ai-search' } = Astro.props;
---

<ai-search data-endpoint={endpoint}>
  <form data-form role="search">
    <label for="ai-search-input">Ask a question</label>
    <input
      id="ai-search-input"
      data-input
      type="search"
      name="query"
      minlength="3"
      required
    />
    <button type="submit" data-submit>Ask</button>
  </form>
  <output data-response aria-live="polite"></output>
  <section data-sources-section hidden>
    <h2>Sources</h2>
    <ul data-sources></ul>
  </section>
</ai-search>

<script src="./AiSearch.client.ts"></script>

<style>
  ai-search {
    display: block;
  }
  [data-response] {
    display: block;
    white-space: pre-wrap;
    margin-block-start: 1rem;
  }
</style>
