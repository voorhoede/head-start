---
import type { CdaStructuredTextRecord } from 'datocms-structured-text-utils';
import { type CdaStructuredTextValue } from 'datocms-structured-text-utils';
import { StructuredText } from '@datocms/astro/StructuredText';
import LinkToRecord from '../LinkToRecord/LinkToRecord.astro';
import Heading from './nodes/Heading.astro';
import Paragraph from './nodes/Paragraph.astro';
import Block from './nodes/Block.astro';
import ItemLink from './nodes/ItemLink.astro';

interface Props {
  data: CdaStructuredTextValue;
}
// TODO CHECK language on code block -> we dont want it

const { data } = Astro.props;

const getTypenames = (records: CdaStructuredTextRecord[] | undefined) => [
  ...new Set(records?.map((r: CdaStructuredTextRecord) => r.__typename)),
];

const blockComponents = Object.fromEntries(
  getTypenames(data?.blocks).map((typename) => [typename, Block]),
);
const inlineBlockComponents = Object.fromEntries(
  getTypenames(data?.inlineBlocks).map((typename) => [typename, Block]),
);
const linkToRecordComponents = Object.fromEntries(
  getTypenames(data?.links).map((typename) => [typename, ItemLink]),
);
const inlineRecordComponents = Object.fromEntries(
  getTypenames(data?.links).map((typename) => [typename, LinkToRecord]),
);
---

<StructuredText
  data={data}
  blockComponents={blockComponents}
  inlineBlockComponents={inlineBlockComponents}
  inlineRecordComponents={inlineRecordComponents}
  linkToRecordComponents={linkToRecordComponents}
  nodeOverrides={{
    heading: Heading,
    paragraph: Paragraph,
  }}
/>
