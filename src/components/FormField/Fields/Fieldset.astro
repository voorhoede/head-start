---
import type { HTMLAttributes } from 'astro/types';
import CheckboxGroup from './CheckboxGroup.astro';
import RadioGroup from './RadioGroup.astro';

type Option = { label: string; value: string };

type Props = HTMLAttributes<'fieldset'> & {
  id: string;
  label: string;
  name: string;
  fieldType: 'checkbox' | 'radio';
  value?: string;
  required?: boolean;
  error?: string;
  options: Option[];
};

const { id, label, name, fieldType, value, required = false, error, options, ...props } = Astro.props;
---

<fieldset {...props}>
  <legend class="form-field__label">
    {label}{required && <span class="form-field__required" role="presentation">*</span>}
  </legend>
  {fieldType === 'checkbox' && (
    <CheckboxGroup {name} {required} {value} {options} class="form-field__input" />
  )}
  {fieldType === 'radio' && (
    <RadioGroup {id} {name} {required} {value} {options} class="form-field__input" />
  )}
  {error && <span class="form-field__error">{error}</span>}
</fieldset>
