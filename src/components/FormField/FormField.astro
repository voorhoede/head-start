---
import type { HTMLAttributes } from 'astro/types';
import Input from './Fields/Input.astro';
import InputEmail from './Fields/InputEmail.astro';
import InputTel from './Fields/InputTel.astro';
import InputNumber from './Fields/InputNumber.astro';
import InputDate from './Fields/InputDate.astro';
import Textarea from './Fields/Textarea.astro';
import Select from './Fields/Select.astro';
import Fieldset from './Fields/Fieldset.astro';

export const fieldTypes = [
  'text',
  'email',
  'phone',
  'textarea',
  'select',
  'checkbox',
  'radio',
  'number',
  'date',
] as const;
export type FieldType = (typeof fieldTypes)[number];

type Option = { label: string; value: string };

export interface Props extends HTMLAttributes<'div'> {
  id: string;
  label: string;
  name: string;
  value?: string;
  required?: boolean;
  error?: string;
  fieldType: FieldType;
  placeholder?: string;
  options?: Option[];
  inputWidth?: string | null;
}

export function isValidFieldType(fieldType: unknown): fieldType is FieldType {
  return ([...fieldTypes] as unknown[]).includes(fieldType);
}

const spanMap: Record<string, number> = {
  'span-1': 1,
  'span-2': 2,
  'span-3': 3,
  'span-4': 4,
};

const {
  class: className,
  id,
  label,
  name,
  value,
  required = false,
  error,
  fieldType,
  placeholder = '',
  options,
  inputWidth,
  ...props
} = Astro.props;

const span = inputWidth ? (spanMap[inputWidth] ?? 4) : 4;

const classList = [
  'form-field',
  `form-field--${fieldType}`,
  ...(error ? ['form-field--error'] : []),
  ...(className ? [className] : []),
];

const isInputGroup =
  (fieldType === 'checkbox' || fieldType === 'radio') && !!options?.length;
---

{
  isInputGroup && (
    <Fieldset
      {id}
      {label}
      {name}
      {fieldType}
      {value}
      {required}
      {error}
      options={options!}
      class:list={classList}
      style={`grid-column: span ${span}`}
      {...props}
    />
  )
}

{
  !isInputGroup && (
    <div class:list={classList} style={`grid-column: span ${span}`} {...props}>
      <label for={id} class="form-field__label">
        {label}
        {required && (
          <span class="form-field__required" role="presentation">
            *
          </span>
        )}
      </label>
      {(fieldType === 'checkbox' || fieldType === 'radio') && (
        <input
          type={fieldType}
          {id}
          {name}
          checked={!!value}
          required={required}
          class="form-field__input"
        />
      )}
      {fieldType === 'select' && (
        <Select
          {id}
          {name}
          {required}
          {value}
          {options}
          class="form-field__input"
        />
      )}
      {fieldType === 'textarea' && (
        <Textarea
          {id}
          {name}
          {required}
          {placeholder}
          {value}
          class="form-field__input"
        />
      )}
      {fieldType === 'number' && (
        <InputNumber
          {id}
          {name}
          {required}
          {placeholder}
          {value}
          class="form-field__input"
        />
      )}
      {fieldType === 'date' && (
        <InputDate
        {id}
        {name}
        {required}
        {value}
        class="form-field__input"
        />
      )}
      {fieldType === 'email' && (
        <InputEmail
          {id}
          {name}
          {required}
          {placeholder}
          {value}
          class="form-field__input"
        />
      )}
      {fieldType === 'phone' && (
        <InputTel
          {id}
          {name}
          {required}
          {placeholder}
          {value}
          class="form-field__input"
        />
      )}
      {(fieldType === 'text' || !isValidFieldType(fieldType)) && (
        <Input
          {id}
          {name}
          {required}
          {placeholder}
          {value}
          class="form-field__input"
        />
      )}
      {error && <span class="form-field__error">{error}</span>}
    </div>
  )
}
