DATOCMS_READONLY_API_TOKEN="<Read-only API token>"
DATOCMS_API_TOKEN="<Full-access API token>"
HEAD_START_PREVIEW_SECRET=""

# AI Search (optional). When all four are set, build-time indexing runs and the query endpoint is functional.
# Cloudflare account ID: dashboard > Workers & Pages > right sidebar.
CLOUDFLARE_ACCOUNT_ID=""
# API token with AI Search:Edit + AI Search:Run + Workers KV Storage:Edit. Create at dashboard > My Profile > API Tokens.
CLOUDFLARE_API_TOKEN=""
# AI Search instance name (must be created in dashboard with built-in storage).
CLOUDFLARE_AI_SEARCH_INSTANCE_NAME=""
# KV namespace ID for the hash store. Create with: wrangler kv namespace create AI_SEARCH_HASHES
CLOUDFLARE_AI_SEARCH_KV_NAMESPACE_ID=""
