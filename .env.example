DATOCMS_READONLY_API_TOKEN="<Read-only API token>"
DATOCMS_API_TOKEN="<Full-access API token>"
HEAD_START_PREVIEW_SECRET=""

# AI Search (optional). Needed for `npm run index:ai-search` and /api/ai-search.
CLOUDFLARE_ACCOUNT_ID="<Cloudflare account ID>"
CLOUDFLARE_API_TOKEN="<API token with AI Search:Edit, AI Search:Run, Workers KV Storage:Edit>"
# Instance must declare custom metadata fields: url, title, description, language.
CLOUDFLARE_AI_SEARCH_INSTANCE_NAME="<AI Search instance name>"
# KV namespace used by the indexer to skip unchanged pages. Leave empty to re-upload every run.
CLOUDFLARE_AI_SEARCH_KV_NAMESPACE_ID=""
# Deployed site the indexer crawls (reads its sitemap). CI sets this from the deploy URL.
SITE_URL="https://head-start.pages.dev"
